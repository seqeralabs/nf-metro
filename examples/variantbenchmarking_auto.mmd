        merge_res[Merge\nTP/FP/FN]
        vcf2csv[VCF to\nCSV]
        sum_stats[Summary\nStats]
        plots[Plots]
        datavzrd_tool[datavzrd]
        merged_csvs[Merged\nCSVs]
        merged_csvs_out[ ]
        bench_summaries[Benchmarking\nSummaries]
