%%metro title: Mismatched Tracks
%%metro style: dark
%%metro line: a | Alpha | #0570b0
%%metro line: b | Beta | #2db572
%%metro line: c | Gamma | #e31a1c
%%metro line: d | Delta | #ff7f00
%%metro line: e | Epsilon | #6a3d9a

graph LR
    subgraph tall [Tall Section]
        t_start[Start]
        t_a[Path A]
        t_b[Path B]
        t_c[Path C]
        t_d[Path D]
        t_e[Path E]
        t_end[End]
        t_start -->|a| t_a
        t_start -->|b| t_b
        t_start -->|c| t_c
        t_start -->|d| t_d
        t_start -->|e| t_e
        t_a -->|a| t_end
        t_b -->|b| t_end
        t_c -->|c| t_end
        t_d -->|d| t_end
        t_e -->|e| t_end
    end

    subgraph short_a [Short A]
        sa1[Proc A]
        sa2[Done A]
        sa1 -->|a| sa2
    end

    subgraph short_b [Short B]
        sb1[Proc B]
        sb2[Done B]
        sb1 -->|b| sb2
    end

    t_end -->|a| sa1
    t_end -->|b| sb1
