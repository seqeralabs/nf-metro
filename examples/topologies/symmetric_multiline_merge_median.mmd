%%metro title: Symmetric multi-line merge
%%metro diamond_style: symmetric
%%metro line: top | Top | #f5c542
%%metro line: mid | Mid | #0570b0
%%metro line: bottom | Bottom | #ff8c00

graph LR
    subgraph section1 [Section]
        %%metro entry: left | top, mid, bottom
        node_top[Top]
        node_mid[Mid]
        node_bottom[Bottom]
        merge[Merge]

        node_top -->|top| merge
        node_mid -->|mid| merge
        node_bottom -->|bottom| merge
    end
