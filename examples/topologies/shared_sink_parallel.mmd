%%metro title: Shared Sink Parallel
%%metro style: dark
%%metro line: alpha | Alpha | #e63946
%%metro line: beta | Beta | #2db572
%%metro line: gamma | Gamma | #0570b0

graph LR
    subgraph src [Source]
        s1[Input]
        s2[Prepare]
        s1 -->|alpha,beta,gamma| s2
    end

    subgraph branch_a [Branch A]
        a1[Step A1]
        a2[Step A2]
        a1 -->|alpha,beta,gamma| a2
    end

    subgraph branch_b [Branch B]
        b1[Step B1]
        b2[Step B2]
        b1 -->|alpha,beta,gamma| b2
    end

    subgraph branch_c [Branch C]
        c1[Step C1]
        c2[Step C2]
        c1 -->|alpha,beta,gamma| c2
    end

    subgraph sink [Sink]
        m1[Merge]
        m2[Report]
        m1 -->|alpha,beta,gamma| m2
    end

    s2 -->|alpha,beta,gamma| a1
    s2 -->|alpha,beta,gamma| b1
    s2 -->|alpha,beta,gamma| c1
    a2 -->|alpha,beta,gamma| m1
    b2 -->|alpha,beta,gamma| m1
    c2 -->|alpha,beta,gamma| m1
