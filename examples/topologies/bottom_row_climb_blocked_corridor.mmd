%%metro title: Bottom-row climb past a blocked corridor
%%metro style: dark
%%metro line: main | Main | #2db572
%%metro line: side | Side | #ff8c00
%%metro grid: feed | 0,0
%%metro grid: low | 1,1
%%metro grid: block | 2,1
%%metro grid: mid | 3,0
%%metro grid: dest | 4,0

graph LR
    subgraph feed [Feed]
        a[A]
    end

    subgraph low [Low]
        x[X]
    end

    subgraph block [Block]
        b[B]
    end

    subgraph mid [Mid]
        m[M]
    end

    subgraph dest [Dest]
        z[Z]
    end

    a -->|main| m
    m -->|main| z
    a -->|main| b
    b -->|main| z

    a -->|side| x
    x -->|side| z
