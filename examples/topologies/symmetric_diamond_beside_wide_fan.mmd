        toolB -->|l1,l2,l3,l4,l5,l6| qc

        qc -->|l1,l2,l3,l4,l5,l6| splitA
        qc -->|l1,l2,l3,l4,l5,l6| splitB
        qc -->|l1,l2,l3,l4,l5,l6| splitC
        splitA -->|l1,l2,l3,l4,l5,l6| qc2
        splitB -->|l1,l2,l3,l4,l5,l6| qc2
        splitC -->|l1,l2,l3,l4,l5,l6| qc2
    end
