        ref_in -->|main| align
        gtf_in -->|main| align
        vcf_in -->|main| align
        bed_in -->|main| align
        align -->|main| annotate
    end

    subgraph output [Output]
        report[Report]
    end

    prep -->|main| align
    annotate -->|main| report
