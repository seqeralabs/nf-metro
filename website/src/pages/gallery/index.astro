---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { getCollection } from "astro:content";
import Metro from "@components/Metro.astro";
import { base } from "../../site";
import { ogImageHead } from "../../lib/og-head";
import { GALLERY_PAGE } from "../../lib/page-meta";

const allEntries = await getCollection("gallery");
const entries = allEntries.sort((a, b) => a.data.order - b.data.order);

// Group entries by category, preserving gallery.yaml insertion order.
const byCategory = new Map<string, typeof entries>();
for (const entry of entries) {
  const cat = entry.data.category;
  if (!byCategory.has(cat)) byCategory.set(cat, []);
  byCategory.get(cat)!.push(entry);
}

function slugify(text: string): string {
  return text.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
}

const headings = Array.from(byCategory.keys()).map((cat) => ({
  depth: 2,
  slug: slugify(cat),
  text: cat,
}));
---

<StarlightPage
  frontmatter={{
    title: GALLERY_PAGE.title,
    description: GALLERY_PAGE.description,
    template: "doc",
    tableOfContents: true,
    pagefind: true,
    prev: false,
    next: false,
    head: ogImageHead("og/gallery.png"),
  }}
  headings={headings}
>
  <p>
    Examples covering the full range of layout patterns.
  </p>

  {
    Array.from(byCategory.entries()).map(([category, items]) => (
      <section class="nfm-gallery-section">
        <h2 id={slugify(category)}>{category}</h2>
        {items.map((entry) => (
          <div class="nfm-gallery-entry">
            <h3>
              <a href={`${base}gallery/${entry.id}/`}>{entry.data.title}</a>
            </h3>
            <p class="nfm-entry-desc">{entry.data.description}</p>
            <Metro src={entry.data.src} purpose="showcase" />
          </div>
        ))}
      </section>
    ))
  }
</StarlightPage>

<style>
  .nfm-gallery-section {
    margin-block: 2rem;
  }

  .nfm-gallery-section h2 {
    font-size: var(--sl-text-h4);
    border-bottom: 1px solid var(--sl-color-hairline);
    padding-bottom: 0.4rem;
    margin-bottom: 1.5rem;
  }

  .nfm-gallery-entry {
    margin-bottom: 2.5rem;
  }

  .nfm-gallery-entry h3 {
    font-size: var(--sl-text-h5);
    margin-bottom: 0.25rem;
  }

  .nfm-gallery-entry h3 a {
    color: var(--sl-color-text-accent);
    text-decoration: none;
  }

  .nfm-gallery-entry h3 a:hover {
    text-decoration: underline;
  }

  .nfm-entry-desc {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    margin-bottom: 0.75rem;
  }
</style>
