%%metro title: riboseq (te + psite_id excerpt)
%%metro style: dark
%%metro file: report_ribowaltz | HTML | riboWaltz
%%metro file: orf_catalogue | BED | ORF catalogue
%%metro file: report_te | HTML | TE report
%%metro off_track: orf_catalogue
%%metro line: riboseq | Ribo-seq | #e6007e
%%metro line: rnaseq | Matched RNA-seq (optional) | #2db572
%%metro fold_threshold: 4

graph LR
    subgraph alignment [Alignment]
        %%metro exit: right | riboseq, rnaseq
        umi_dedup[UMI-tools Dedup]
    end

    subgraph orf_calling [Extended ORF discovery & calling]
        %%metro entry: left | riboseq
        ribotish[Ribo-TISH]
        orf_merge[Merge ORF catalogue]
        ribotish -->|riboseq| orf_merge
        orf_merge -->|riboseq| orf_catalogue
    end

    subgraph psite_id [P-site identification]
        %%metro entry: left | riboseq
        ribowaltz[riboWaltz]
        plastid_psite[plastid P-site]
        plastid_wiggle[plastid Wiggle]
        quantify_orf_psite[Quantify ORF P-sites]

        ribowaltz -->|riboseq| report_ribowaltz
        plastid_psite -->|riboseq| plastid_wiggle
        orf_catalogue -->|riboseq| quantify_orf_psite
        plastid_wiggle -->|riboseq| quantify_orf_psite
    end

    subgraph quantification [Quantification]
        %%metro entry: left | riboseq, rnaseq
        %%metro exit: right | riboseq, rnaseq
        salmon_quant[Salmon]
    end

    subgraph te [Translational efficiency]
        %%metro entry: left | riboseq, rnaseq
        psite_counts[Plastid P-site counts]
        te_counts_prep[Prep TE counts]
        anota2seq[anota2seq]
        deltate[DESeq2 deltaTE]

        psite_counts -->|riboseq| te_counts_prep
        te_counts_prep -->|riboseq,rnaseq| anota2seq
        te_counts_prep -->|riboseq,rnaseq| deltate
        anota2seq -->|riboseq,rnaseq| report_te
        deltate -->|riboseq,rnaseq| report_te
    end

    %% Inter-section edges
    umi_dedup -->|riboseq| ribotish
    umi_dedup -->|riboseq| ribowaltz
    umi_dedup -->|riboseq| plastid_psite
    umi_dedup -->|riboseq,rnaseq| salmon_quant
    plastid_wiggle -->|riboseq| psite_counts
    salmon_quant -->|rnaseq| te_counts_prep
